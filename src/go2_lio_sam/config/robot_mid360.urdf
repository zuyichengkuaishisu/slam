<?xml version="1.0"?>
<robot name="lio_mid360">
  <link name="chassis_link"/>

  <link name="base_link"/>
  <joint name="base_link_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="livox_frame"/>
  <!-- Mid360 mounting estimated from bag IMU gravity: roll=-15.17deg, pitch=27.69deg. -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="livox_frame"/>
    <origin xyz="0 0 0" rpy="-0.264681 0.483277 0"/>
  </joint>

  <!-- Mid360 内置 IMU，驱动话题 frame_id 同为 livox_frame，与雷达同安装角 -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="livox_frame"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="laser_sensor_frame"/>
  <joint name="laser_joint" type="fixed">
    <parent link="imu_link"/>
    <child link="laser_sensor_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="navsat_link"/>
  <joint name="navsat_joint" type="fixed">
    <parent link="chassis_link"/>
    <child link="navsat_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</robot>
